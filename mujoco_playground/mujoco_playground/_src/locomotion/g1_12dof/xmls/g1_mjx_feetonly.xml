    <position class="hip_roll"   name="right_hip_roll_joint"    joint="right_hip_roll_joint"/>
    <position class="hip_yaw"    name="right_hip_yaw_joint"     joint="right_hip_yaw_joint"/>
    <position class="knee"       name="right_knee_joint"        joint="right_knee_joint"/>
    <position class="ankle_pitch" name="right_ankle_pitch_joint" joint="right_ankle_pitch_joint"/>
    <position class="ankle_roll"  name="right_ankle_roll_joint"  joint="right_ankle_roll_joint"/>
  </actuator>

  <sensor>
    <!-- 仅 pelvis IMU 与脚部传感 -->
    <gyro site="imu" name="gyro_pelvis"/>
    <velocimeter site="imu" name="local_linvel_pelvis"/>
    <accelerometer site="imu" name="accelerometer_pelvis"/>
    <framezaxis objtype="site" objname="imu" name="upvector_pelvis"/>
    <framexaxis objtype="site" objname="imu" name="forwardvector_pelvis"/>
    <framelinvel objtype="site" objname="imu" name="global_linvel_pelvis"/>
    <frameangvel objtype="site" objname="imu" name="global_angvel_pelvis"/>
    <framepos objtype="site" objname="imu" name="position_pelvis"/>
    <framequat objtype="site" objname="imu" name="orientation_pelvis"/>

    <framelinvel objtype="site" objname="left_foot"  name="left_foot_global_linvel"/>
    <framelinvel objtype="site" objname="right_foot" name="right_foot_global_linvel"/>
    <force name="left_foot_force"  site="left_foot"/>
    <force name="right_foot_force" site="right_foot"/>
    <framepos objtype="site" objname="left_foot" name="left_foot_pos"/>
    <framepos objtype="site" objname="right_foot" name="right_foot_pos"/>
  

    <!-- pelvis -->
    <framelinvel objtype="body" objname="pelvis" name="pelvis_global_linvel"/>
    <frameangvel objtype="body" objname="pelvis" name="pelvis_global_angvel"/>
    <!-- 左腿 -->
    <framelinvel objtype="body" objname="left_hip_roll_link"  name="left_hip_roll_link_global_linvel"/>
    <frameangvel objtype="body" objname="left_hip_roll_link"  name="left_hip_roll_link_global_angvel"/>

    <framelinvel objtype="body" objname="left_knee_link"       name="left_knee_link_global_linvel"/>
    <frameangvel objtype="body" objname="left_knee_link"       name="left_knee_link_global_angvel"/>

    <framelinvel objtype="body" objname="left_ankle_roll_link" name="left_ankle_roll_link_global_linvel"/>
    <frameangvel objtype="body" objname="left_ankle_roll_link" name="left_ankle_roll_link_global_angvel"/>

    <!-- 右腿 -->
    <framelinvel objtype="body" objname="right_hip_roll_link"  name="right_hip_roll_link_global_linvel"/>
    <frameangvel objtype="body" objname="right_hip_roll_link"  name="right_hip_roll_link_global_angvel"/>

    <framelinvel objtype="body" objname="right_knee_link"      name="right_knee_link_global_linvel"/>
    <frameangvel objtype="body" objname="right_knee_link"      name="right_knee_link_global_angvel"/>

    <framelinvel objtype="body" objname="right_ankle_roll_link" name="right_ankle_roll_link_global_linvel"/>
    <frameangvel objtype="body" objname="right_ankle_roll_link" name="right_ankle_roll_link_global_angvel"/>

  </sensor>
</mujoco>
