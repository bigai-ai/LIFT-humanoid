<mujoco model="g1_12dof">
  <compiler angle="radian" meshdir="meshes/" />

  <!-- <option iterations="3" ls_iterations="5" timestep=".002" integrator="Euler">
    <flag eulerdamp="disable"/>
  </option> -->
  <option iterations="50" timestep='0.002' tolerance="1e-10" solver="Newton" jacobian="dense" cone="pyramidal" />

  <custom>
      <numeric data="0.   0.  0.8 1.   0.   0.   0  -0.312 0 0 0.669 -0.363 0 -0.312 0 0 0.669 -0.363 0"  name="init_qpos"/>
      <numeric data="0" name="matrix_inv_iterations"/>
      <numeric data="20" name="solver_maxls"/>
  </custom>

  <default>
      <joint armature="0.01" frictionloss="0.0" />
  </default>

  <default>
    <default class="g1">
      <!-- 与原 G1 一致的碰撞/控制风格 -->
      <geom condim="1" contype="0" conaffinity="0"/>
      <default class="hip">
        <default class="hip_pitch">
          <joint axis="0 1 0" range="-2.5307 2.8798"/>
        </default>
        <default class="hip_roll">
          <joint axis="1 0 0" range="-0.5236 2.9671"/>
        </default>
        <default class="hip_yaw">
          <joint axis="0 0 1" range="-2.7576 2.7576"/>
        </default>
      </default>
      <default class="knee">
        <joint axis="0 1 0" range="-0.087267 2.8798"/>
      </default>
      <default class="ankle">
        <default class="ankle_pitch">
          <joint axis="0 1 0" range="-0.87267 0.5236"/>
        </default>
        <default class="ankle_roll">
          <joint axis="1 0 0" range="-0.2618 0.2618"/>
        </default>
      </default>

      <default class="visual">
        <geom group="2" type="mesh" density="0" material="silver"/>
      </default>
      <default class="collision">
        <geom group="3" rgba=".2 .6 .2 .3"/>
        <default class="foot">
          <!-- 可按需调大 size 或改为更贴合脚底的形状 -->
          <geom size="0.085 0.03 0.005" type="box"
                contype="1" conaffinity="1" condim="3"/>
        </default>
      </default>

      <site group="5" rgba="1 0 0 1"/>
    </default>
  </default>





  <asset>
    <texture type="skybox" builtin="gradient" rgb1="1.0 1.0 1.0" rgb2="1.0 1.0 1.0" width="512" height="512"/>
    <texture name="plane" type="2d" builtin="flat" rgb1="1 1 1" rgb2="1 1 1" width="512" height="512" mark="cross" markrgb="0 0 0"/>
    <material name="plane" reflectance="0.0" texture="plane" texrepeat="3 3" texuniform="true"/>
    <material name="silver" rgba="0.7 0.7 0.7 1"/>
    <material name="black" rgba="0.2 0.2 0.2 1"/>

    <!-- 只保留下肢所需 mesh（以及骨盆） -->
    <mesh name="pelvis" file="pelvis.STL"/>
    <mesh name="pelvis_contour_link" file="pelvis_contour_link.STL"/>

    <mesh name="left_hip_pitch_link"  file="left_hip_pitch_link.STL"/>
    <mesh name="left_hip_roll_link"   file="left_hip_roll_link.STL"/>
    <mesh name="left_hip_yaw_link"    file="left_hip_yaw_link.STL"/>
    <mesh name="left_knee_link"       file="left_knee_link.STL"/>
    <mesh name="left_ankle_pitch_link" file="left_ankle_pitch_link.STL"/>
    <mesh name="left_ankle_roll_link"  file="left_ankle_roll_link.STL"/>

    <mesh name="right_hip_pitch_link" file="right_hip_pitch_link.STL"/>
    <mesh name="right_hip_roll_link"  file="right_hip_roll_link.STL"/>
    <mesh name="right_hip_yaw_link"   file="right_hip_yaw_link.STL"/>
    <mesh name="right_knee_link"      file="right_knee_link.STL"/>
    <mesh name="right_ankle_pitch_link" file="right_ankle_pitch_link.STL"/>
    <mesh name="right_ankle_roll_link"  file="right_ankle_roll_link.STL"/>
    <!-- Upper body visual meshes -->
    <mesh name="waist_yaw_link"   file="waist_yaw_link_rev_1_0.STL"/>
    <mesh name="waist_roll_link"  file="waist_roll_link_rev_1_0.STL"/>
    <mesh name="torso_link"       file="torso_link_rev_1_0.STL"/>
    <mesh name="logo_link"        file="logo_link.STL"/>
    <mesh name="head_link"        file="head_link.STL"/>

    <mesh name="left_shoulder_pitch_link"  file="left_shoulder_pitch_link.STL"/>
    <mesh name="left_shoulder_roll_link"   file="left_shoulder_roll_link.STL"/>
    <mesh name="left_shoulder_yaw_link"    file="left_shoulder_yaw_link.STL"/>
    <mesh name="left_elbow_link"           file="left_elbow_link.STL"/>
    <mesh name="left_wrist_roll_link"      file="left_wrist_roll_link.STL"/>
    <mesh name="left_wrist_pitch_link"     file="left_wrist_pitch_link.STL"/>
    <mesh name="left_wrist_yaw_link"       file="left_wrist_yaw_link.STL"/>
    <mesh name="left_rubber_hand"          file="left_rubber_hand.STL"/>

    <mesh name="right_shoulder_pitch_link" file="right_shoulder_pitch_link.STL"/>
    <mesh name="right_shoulder_roll_link"  file="right_shoulder_roll_link.STL"/>
    <mesh name="right_shoulder_yaw_link"   file="right_shoulder_yaw_link.STL"/>
    <mesh name="right_elbow_link"          file="right_elbow_link.STL"/>
    <mesh name="right_wrist_roll_link"     file="right_wrist_roll_link.STL"/>
    <mesh name="right_wrist_pitch_link"    file="right_wrist_pitch_link.STL"/>
    <mesh name="right_wrist_yaw_link"      file="right_wrist_yaw_link.STL"/>
    <mesh name="right_rubber_hand"         file="right_rubber_hand.STL"/>

  
  </asset>

  <worldbody>
    <light directional="true" diffuse=".4 .4 .4" specular="0.1 0.1 0.1" pos="0 0 5.0" dir="0 0 -1" castshadow="false" />
    <light directional="true" diffuse=".6 .6 .6" specular="0.2 0.2 0.2" pos="0 0 4" dir="0 0 -1" />
    <!-- <geom name="ground" type="plane" pos="0 0 0" size="0 0 1" material="matplane" condim="1"/> -->
    <geom name='floor' type='plane' contype='1' conaffinity='1' rgba="0.5 0.9 0.9 0.1" material='plane' pos='0 0 0' size='0 0 1'/>
    <body name="pelvis" pos="0 0 0.793" childclass="g1">
      <camera name="track" pos="1.734 -1.135 .35" xyaxes="0.552 0.834 -0.000 -0.170 0.112 0.979" mode="trackcom"/>
      <inertial pos="0 0 -0.07605" quat="1 0 -0.000399148 0" mass="3.813" diaginertia="0.010549 0.0093089 0.0079184"/>
      <joint type="free" />

      <geom class="visual" material="black" mesh="pelvis"/>
      <geom class="visual" mesh="pelvis_contour_link"/>

      <!-- 左腿（沿用 29-DoF 的几何、惯量与相对位姿） -->
      <body name="left_hip_pitch_link" pos="0 0.064452 -0.1027">
        <inertial pos="0.002741 0.047791 -0.02606" quat="0.954862 0.293964 0.0302556 0.030122" mass="1.35"
          diaginertia="0.00181517 0.00153422 0.00116212"/>
        <joint name="left_hip_pitch_joint" class="hip_pitch"/>
        <geom class="visual" material="black" mesh="left_hip_pitch_link"/>

        <body name="left_hip_roll_link" pos="0 0.052 -0.030465" quat="0.996179 0 -0.0873386 0">
          <inertial pos="0.029812 -0.001045 -0.087934" quat="0.977808 -1.97119e-05 0.205576 -0.0403793" mass="1.52"
            diaginertia="0.00254986 0.00241169 0.00148755"/>
          <joint name="left_hip_roll_joint" class="hip_roll"/>
          <geom class="visual" mesh="left_hip_roll_link"/>
          <!-- <geom name="left_thigh" class="collision" type="capsule" size="0.06" fromto="0.02 0 0 0.02 0 -0.2"/> -->

          <body name="left_hip_yaw_link" pos="0.025001 0 -0.12412">
            <inertial pos="-0.057709 -0.010981 -0.15078" quat="0.600598 0.15832 0.223482 0.751181" mass="1.702"
              diaginertia="0.00776166 0.00717575 0.00160139"/>
            <joint name="left_hip_yaw_joint" class="hip_yaw"/>
            <geom class="visual" mesh="left_hip_yaw_link"/>

            <body name="left_knee_link" pos="-0.078273 0.0021489 -0.17734" quat="0.996179 0 0.0873386 0">
              <inertial pos="0.005457 0.003964 -0.12074" quat="0.923418 -0.0327699 0.0158246 0.382067" mass="1.932"
                diaginertia="0.0113804 0.0112778 0.00146458"/>
              <joint name="left_knee_joint" class="knee"/>
              <geom class="visual" mesh="left_knee_link"/>
              <!-- <geom name="left_shin" class="collision" type="capsule" size="0.08" fromto="0.02 0 0 0.02 0 -0.25"/> -->

              <body name="left_ankle_pitch_link" pos="0 -9.4445e-05 -0.30001">
                <inertial pos="-0.007269 0 0.011137" quat="0.603053 0.369225 0.369225 0.603053" mass="0.074"
                  diaginertia="1.89e-05 1.40805e-05 6.9195e-06"/>
                <joint name="left_ankle_pitch_joint" class="ankle_pitch"/>
                <geom class="visual" mesh="left_ankle_pitch_link"/>

                <body name="left_ankle_roll_link" pos="0 0 -0.017558">
                  <inertial pos="0.026505 0 -0.016425" quat="-0.000481092 0.728482 -0.000618967 0.685065" mass="0.608"
                    diaginertia="0.00167218 0.0016161 0.000217621"/>
                  <joint name="left_ankle_roll_joint" class="ankle_roll"/>
                  <geom class="visual" material="black" mesh="left_ankle_roll_link"/>

                  <!-- 脚底碰撞与站立 site -->
                  <geom name="left_foot" class="foot" pos="0.04 0 -0.029" size="0.09 0.03 0.008" type="box"/>
                  <site name="left_foot" pos="0 0 0" size="0.01"/>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>

      <!-- 右腿（镜像保持与原 29-DoF 一致） -->
      <body name="right_hip_pitch_link" pos="0 -0.064452 -0.1027">
        <inertial pos="0.002741 -0.047791 -0.02606" quat="0.954862 -0.293964 0.0302556 -0.030122" mass="1.35"
          diaginertia="0.00181517 0.00153422 0.00116212"/>
        <joint name="right_hip_pitch_joint" class="hip_pitch"/>
        <geom class="visual" material="black" mesh="right_hip_pitch_link"/>

        <body name="right_hip_roll_link" pos="0 -0.052 -0.030465" quat="0.996179 0 -0.0873386 0">
          <inertial pos="0.029812 0.001045 -0.087934" quat="0.977808 1.97119e-05 0.205576 0.0403793" mass="1.52"
            diaginertia="0.00254986 0.00241169 0.00148755"/>
          <joint name="right_hip_roll_joint" class="hip_roll"/>
          <geom class="visual" mesh="right_hip_roll_link"/>
          <!-- <geom name="right_thigh" class="collision" type="capsule" size="0.06" fromto="0.02 0 0 0.02 0 -0.2"/> -->

          <body name="right_hip_yaw_link" pos="0.025001 0 -0.12412">
            <inertial pos="-0.057709 0.010981 -0.15078" quat="0.751181 0.223482 0.15832 0.600598" mass="1.702"
              diaginertia="0.00776166 0.00717575 0.00160139"/>
            <joint name="right_hip_yaw_joint" class="hip_yaw"/>
            <geom class="visual" mesh="right_hip_yaw_link"/>

            <body name="right_knee_link" pos="-0.078273 -0.0021489 -0.17734" quat="0.996179 0 0.0873386 0">
              <inertial pos="0.005457 -0.003964 -0.12074" quat="0.923439 0.0345276 0.0116333 -0.382012" mass="1.932"
                diaginertia="0.011374 0.0112843 0.00146452"/>
              <joint name="right_knee_joint" class="knee"/>
              <geom class="visual" mesh="right_knee_link"/>
              <!-- <geom name="right_shin" class="collision" type="capsule" size="0.08" fromto="0.02 0 0 0.02 0 -0.25"/> -->

              <body name="right_ankle_pitch_link" pos="0 9.4445e-05 -0.30001">
                <inertial pos="-0.007269 0 0.011137" quat="0.603053 0.369225 0.369225 0.603053" mass="0.074"
                  diaginertia="1.89e-05 1.40805e-05 6.9195e-06"/>
                <joint name="right_ankle_pitch_joint" class="ankle_pitch"/>
                <geom class="visual" mesh="right_ankle_pitch_link"/>

                <body name="right_ankle_roll_link" pos="0 0 -0.017558">
                  <inertial pos="0.026505 0 -0.016425" quat="0.000481092 0.728482 0.000618967 0.685065" mass="0.608"
                    diaginertia="0.00167218 0.0016161 0.000217621"/>
                  <joint name="right_ankle_roll_joint" class="ankle_roll"/>
                  <geom class="visual" material="black" mesh="right_ankle_roll_link"/>

                  <geom name="right_foot" class="foot" pos="0.04 0 -0.029" size="0.09 0.03 0.008" type="box"/>
                  <site name="right_foot" pos="0 0 0" size="0.01"/>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    <!-- Upper body visualization: geom-only (no bodies/joints/collisions) -->
    <!-- Waist & torso -->
    <geom class="visual" mesh="waist_yaw_link"/>
    <geom class="visual" mesh="waist_roll_link" pos="-0.0039635 0 0.044"/>
    <geom class="visual" mesh="torso_link"      pos="-0.0039635 0 0.044"/>
    <geom class="visual" material="black" mesh="logo_link" pos="0 0 0"/>
    <geom class="visual" material="black" mesh="head_link" pos="0 0 0"/>

    <!-- Left arm (poses composed into pelvis frame) -->
    <geom class="visual" mesh="left_shoulder_pitch_link"
          pos="-0.0000072 0.10022 0.29178"
          quat="0.990264 0.139201 0.0000138722 -0.0000986868"/>
    <geom class="visual" mesh="left_shoulder_roll_link"
          pos="0.000000374 0.140560442 0.28896128"
          quat="0.999999632 0.00002927446 0.0000274716351 -0.0000957957582"/>
    <geom class="visual" mesh="left_shoulder_yaw_link"
          pos="-0.00000410009 0.146806485 0.185761646"
          quat="0.999999632 0.00002927446 0.0000274716351 -0.0000957957582"/>
    <geom class="visual" mesh="left_elbow_link"
          pos="0.01577448 0.14680818 0.10524278"
          quat="0.999999632 0.00002927446 0.0000274716351 -0.0000957957582"/>
    <geom class="visual" mesh="left_wrist_roll_link"
          pos="0.11577429 0.14867751 0.09523739"
          quat="0.999999632 0.00002927446 0.0000274716351 -0.0000957957582"/>
    <geom class="visual" mesh="left_wrist_pitch_link"
          pos="0.15377429 0.14867023 0.09523531"
          quat="0.999999632 0.00002927446 0.0000274716351 -0.0000957957582"/>
    <geom class="visual" mesh="left_wrist_yaw_link"
          pos="0.19977428 0.14866142 0.09523278"
          quat="0.999999632 0.00002927446 0.0000274716351 -0.0000957957582"/>
    <geom class="visual" mesh="left_rubber_hand"
          pos="0.24127486 0.15165347 0.09523067"/>
    <site name="left_palm" pos="0.27977428 0.14864609 0.09522838" size="0.01"/>

    <!-- Right arm -->
    <geom class="visual" mesh="right_shoulder_pitch_link"
          pos="-0.0000072 -0.10021 0.29178"
          quat="0.990264 -0.139201 0.0000138722 0.0000986868"/>
    <geom class="visual" mesh="right_shoulder_roll_link"
          pos="0.000000374 -0.140550442 0.28896128"
          quat="0.999999632 -0.00002927446 0.0000274716351 0.0000957957582"/>
    <geom class="visual" mesh="right_shoulder_yaw_link"
          pos="-0.00000410009 -0.146796485 0.185761646"
          quat="0.999999632 -0.00002927446 0.0000274716351 0.0000957957582"/>
    <geom class="visual" mesh="right_elbow_link"
          pos="0.01577448 -0.14679818 0.10524278"
          quat="0.999999632 -0.00002927446 0.0000274716351 0.0000957957582"/>
    <geom class="visual" mesh="right_wrist_roll_link"
          pos="0.11577429 -0.14866751 0.09523739"
          quat="0.999999632 -0.00002927446 0.0000274716351 0.0000957957582"/>
    <geom class="visual" mesh="right_wrist_pitch_link"
          pos="0.15377429 -0.14866023 0.09523531"
          quat="0.999999632 -0.00002927446 0.0000274716351 0.0000957957582"/>
    <geom class="visual" mesh="right_wrist_yaw_link"
          pos="0.19977428 -0.14865142 0.09523278"
          quat="0.999999632 -0.00002927446 0.0000274716351 0.0000957957582"/>
    <geom class="visual" mesh="right_rubber_hand"
          pos="0.24127486 -0.15164347 0.09523067"/>
    <site name="right_palm" pos="0.27977428 -0.14863609 0.09522838" size="0.01"/>

    </body>
  </worldbody>

  <actuator>
    <!-- 仅 12 DoF（下肢） -->
    <motor class="hip_pitch"  name="left_hip_pitch_joint"   joint="left_hip_pitch_joint"  gear="1"/>
    <motor class="hip_roll"   name="left_hip_roll_joint"    joint="left_hip_roll_joint"  gear="1"/>
    <motor class="hip_yaw"    name="left_hip_yaw_joint"     joint="left_hip_yaw_joint"  gear="1"/>
    <motor class="knee"       name="left_knee_joint"        joint="left_knee_joint"  gear="1"/>
    <motor class="ankle_pitch" name="left_ankle_pitch_joint" joint="left_ankle_pitch_joint"  gear="1"/>
    <motor class="ankle_roll"  name="left_ankle_roll_joint"  joint="left_ankle_roll_joint"  gear="1"/>

    <motor class="hip_pitch"  name="right_hip_pitch_joint"   joint="right_hip_pitch_joint"  gear="1"/>
    <motor class="hip_roll"   name="right_hip_roll_joint"    joint="right_hip_roll_joint"  gear="1"/>
    <motor class="hip_yaw"    name="right_hip_yaw_joint"     joint="right_hip_yaw_joint"  gear="1"/>
    <motor class="knee"       name="right_knee_joint"        joint="right_knee_joint"  gear="1"/>
    <motor class="ankle_pitch" name="right_ankle_pitch_joint" joint="right_ankle_pitch_joint"  gear="1"/>
    <motor class="ankle_roll"  name="right_ankle_roll_joint"  joint="right_ankle_roll_joint"  gear="1"/>
  </actuator>


</mujoco>
